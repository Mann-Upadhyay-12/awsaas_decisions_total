    {
      "title": "Strategy Distribution",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(awsaas_decisions_total) by (strategy)", "refId": "A" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Average Projected Speed Improvement",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(awsaas_projected_improvement_percent_sum[5m]) / rate(awsaas_projected_improvement_percent_count[5m])", "refId": "A" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 60 }
      }
    },
    {
      "title": "Decision Latency (P95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(awsaas_decision_latency_ms_bucket[5m])) by (le))", "legendFormat": "P95 Latency", "refId": "A" }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    }
